    },
    "homepage": "https://github.com/core-ds/arui-scripts/tree/master/packages/brotli-dcb-builder#readme",
    "scripts": {
        "build": "tsc --project tsconfig.json",
        "test": "jest",
        "lint:scripts": "eslint \"**/*.{js,jsx,ts,tsx}\" --ext .js,.jsx,.ts,.tsx",
        "lint": "yarn lint:scripts",
        "lint:fix": "yarn lint:scripts --fix",
        "format": "prettier --write $INIT_CWD/{config,src}/**/*.{ts,tsx,js,jsx,css}",
        "audit": "yarn npm audit --severity high --environment production",
        "dev": "ts-node src/bin.ts"
    },
    "devDependencies": {
        "@types/command-line-args": "^5.2.3",
        "eslint": "^8.20.0",
        "eslint-config-custom": "workspace:*",
        "jest": "28.1.3",
        "prettier": "^2.7.1",
        "ts-jest": "28.0.8",
        "ts-node": "10.9.2",
        "typescript": "4.9.5"
    },
    "dependencies": {
        "brotli-dictionary": "^1.4.0",
        "command-line-args": "^6.0.1"
    }
}
