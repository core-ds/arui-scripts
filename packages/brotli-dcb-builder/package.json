    "main": "./build/index.js",
    "typings": "./build/index.d.ts",
    "bin": "./build/bin.js",
    "license": "MPL-2.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/core-ds/arui-scripts.git"
    },
    "bugs": {
